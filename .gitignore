# ── Dependencies & build output ────────────────────────────
node_modules
dist
build
.svelte-kit
.turbo
.cache
coverage
*.tsbuildinfo

# ── Local env (1Password-resolved at load) ────────────────
# .envrc is generated locally and reads secrets from 1Password.
# Never commit it. .envrc.example IS committed as a template.
.envrc
.env
.env.local
.env.*.local

# ── Cloudflare / Wrangler ─────────────────────────────────
.wrangler
.dev.vars
wrangler-cache

# ── Tooling caches ────────────────────────────────────────
vite.config.ts.timestamp-*.mjs
.playwright-mcp
.vscode/settings.json
.idea

# ── Example local artifacts ───────────────────────────────
examples/**/.claude/
examples/**/.playwright-mcp/
examples/**/.svelte-kit/
examples/**/build/
examples/**/node_modules/
examples/**/output/
examples/**/*.tmp.png
examples/**/*-dark*.png
examples/**/*-light*.png

# ── OS detritus ──────────────────────────────────────────
.DS_Store
Thumbs.db
*.log

# ── Misc ─────────────────────────────────────────────────
*.pem
.tmp
tmp/
