{
  "name": "@a3tai/mittsu-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Native-ish UI primitives. Copy components into your project shadcn-style.",
  "homepage": "https://mittsu.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a3tai/mittsu.git"
  },
  "bugs": {
    "url": "https://github.com/a3tai/mittsu/issues"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "test:cli": "node packages/cli/bin/mittsu.js list --registry ./packages/svelte5/registry.json"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
